PORT=3000
OWNER_LOGIN=owner
OWNER_PASSWORD=stavugolki2026
BOT_TOKEN=
ADMIN_GROUP_CHAT_ID=
CHANNEL_CHAT_ID=
# Для Railway укажите путь к подключенному Volume, например /data
DATA_DIR=/data

# App service: URL мини-приложения. Если не задать, app попробует собрать его из APP_BASE_URL/домена Railway.
MINIAPP_URL=https://your-domain.up.railway.app/shop/
# App service: базовый URL app service без /shop. Нужен server для автонастройки webhook
# и bot service, если он развернут отдельно.
APP_BASE_URL=https://your-app.up.railway.app

# Один и тот же секрет в app и bot service для синхронизации /manager и /posts
CONFIG_SYNC_SECRET=change-me
# Необязательно: отдельный секрет для webhook Telegram. Если не задать, будет вычислен автоматически.
TELEGRAM_WEBHOOK_SECRET=stav_ugolki_webhook_secret
